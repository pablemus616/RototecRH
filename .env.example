# Copiar a `.env.local` y ajustar valores. .env.local NO se sube al repo.

# URL base del gateway. Los endpoints específicos cuelgan como /<recurso>.
# Mientras VITE_USE_MOCK=true no se usa, pero queda configurado para el flip-the-switch.
VITE_API_BASE_URL=http://localhost:3001/api/v2

# true  = mock con localStorage (modo dev/demo sin backend)
# false = backend real apuntando a VITE_API_BASE_URL
VITE_USE_MOCK=true
