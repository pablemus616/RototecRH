# Config de PRODUCCIÓN (Vercel). Vite carga este archivo solo en `vite build`.
#
# IMPORTANTE: la base es RELATIVA (/api/v2), no una URL absoluta. El front pega
# same-origin a https://<deploy>/api/v2/... y el rewrite de vercel.json la proxya
# server-side al backend HTTP. Una URL absoluta http://... rompe con Mixed Content
# (página HTTPS pidiendo recurso HTTP) y además salta el proxy.
VITE_API_BASE_URL=/api/v2

VITE_USE_MOCK=false
